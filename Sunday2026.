<title>血統分析｜モーモー競馬研究所</title>

<style>
/* =============================
   背景（白紫チェック）
============================= */
body{
  font-family: Meiryo, sans-serif;
  margin:0;
  line-height:1.6;

  background:
    linear-gradient(45deg,#ece6ff 25%,transparent 25%),
    linear-gradient(-45deg,#ece6ff 25%,transparent 25%),
    linear-gradient(45deg,transparent 75%,#ece6ff 75%),
    linear-gradient(-45deg,transparent 75%,#ece6ff 75%);
  background-size:24px 24px;
  background-color:#fff;
}

/* =============================
   中央ラッパー
============================= */
.wrapper{
  max-width:1100px;
  margin:40px auto;
  background:#fff;
  padding:30px;
  border:4px solid #2e8b57;
}

/* =============================
   共通
============================= */
h1{
  border-bottom:5px solid #2e8b57;
}

.horse-card{
  margin-top:50px;
  padding:25px;
  border:3px solid #2e8b57;
}

/* =============================
   5代血統ツリー表
============================= */
.pedigree{
  border-collapse:collapse;
  margin-top:20px;
  width:100%;
  font-size:14px;
}

.pedigree td{
  border:1px solid #2e8b57;
  padding:6px;
  text-align:left;
}

/* 牡馬 */
.male td{
  background:#000;
  color:#fff;
}

/* 牝馬 */
.female td{
  background:#fff;
  color:#000;
}

/* =============================
   クロス表
============================= */
.cross{
  margin-top:15px;
  border-collapse:collapse;
  width:60%;
}

.cross th,.cross td{
  border:1px solid #2e8b57;
  padding:6px;
  text-align:center;
}

.cross th{
  background:#2e8b57;
  color:#fff;
}
</style>
</head>

