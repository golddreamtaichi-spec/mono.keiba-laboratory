<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>POG指名リスト</title>

<style>

body{
font-family:Meiryo, sans-serif;
background:#f5f5f5;
padding:30px;
}

h1{
text-align:center;
margin-bottom:30px;
}

/* 表 */

table{
border-collapse:collapse;
width:100%;
max-width:1200px;
margin:auto;
background:#00a651;
color:#fff;
}

th,td{
border:1px solid #004d26;
padding:8px;
}

th{
background:#006837;
font-size:16px;
}

.rank{
width:40px;
text-align:center;
font-weight:bold;
background:#008a44;
}

.horse{
font-weight:bold;
color:#fff;
}

.sire{
color:#ffd800;
font-weight:bold;
}

.dam{
color:#9fe2ff;
}

.trainer{
color:#fff;
}

.owner{
color:#eee;
}

.comment{
background:#00994d;
color:#fff;
}

</style>
</head>

<body>

